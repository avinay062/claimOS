PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/claimsOS?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ── Phase 2 ──────────────────────────────────────

# AWS S3 (for substantiation document uploads — leave blank for dev memory mode)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=claimsOS-documents

# Redis (for BullMQ job queues — leave blank to skip)
REDIS_URL=redis://localhost:6379

# Resend (email notifications — leave blank to log to console)
RESEND_API_KEY=
EMAIL_FROM=ClaimsOS <notifications@yourdomain.com>

# App base URL (used in email links)
APP_URL=http://localhost:3000
